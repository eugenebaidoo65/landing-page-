<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Tech & Apparel Deals</title>
<style>
body {
    font-family: Arial, sans-serif;
    background: #111;
    color: #fff;
    margin: 0;
    padding: 0;
    text-align: center;
}
.container {
    max-width: 1000px;
    margin: auto;
    padding: 20px;
}
h1 {
    font-size: 2.5rem;
    color: #00f5ff;
    margin-top: 40px;
}
p {
    color: #ccc;
}
.products-grid {
    display: grid;
    grid-template-columns: 1fr; /* Single column by default */
    gap: 20px;
    margin-top: 30px;
}
.product {
    background: #1a1a1a;
    padding: 20px;
    border-radius: 10px;
    position: relative;
    transition: transform 0.3s, box-shadow 0.3s;
}
.product:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px #00f5ff;
}
.product img {
    width: 100%;
    max-width: 300px;
    border-radius: 10px;
}
.price {
    color: #00f5ff;
    font-size: 1.5rem;
    margin: 10px 0;
    font-weight: bold;
}
.btn {
    background: #00f5ff;
    color: #000;
    padding: 15px 30px;
    text-decoration: none;
    font-weight: bold;
    border-radius: 50px;
    display: inline-block;
    margin-top: 15px;
    transition: background 0.3s, color 0.3s;
}
.btn:hover {
    background: #fff;
    color: #00f5ff;
}
/* Product label */
.label {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #ff4081;
    color: #fff;
    padding: 5px 10px;
    font-size: 0.9rem;
    font-weight: bold;
    border-radius: 5px;
}

/* Responsive Grid for Tablets and Up */
@media (min-width: 600px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr); /* 2 columns */
    }
}

/* Responsive Grid for Large Screens */
@media (min-width: 900px) {
    .products-grid {
        grid-template-columns: repeat(3, 1fr); /* 3 columns */
    }
}
</style>
</head>
<body>

<div class="container">
    <h1>🔥 Best Deals Online</h1>
    <p>Click any product below to check price and deals!</p>

    <div class="products-grid">
        <!-- Product 1 -->
        <div class="product">
            <div class="label">Hot</div>
            <img src="https://ae-pic-a1.aliexpress-media.com/kf/S00cc9d78b0794c15ba9a62f22dca454eU.jpg_960x960q75.jpg_.avif" alt="Stylish Loungewear Set">
            <h2>Stylish Loungewear Set</h2>
            <div class="price">$59.99</div>
            <a href="https://sovrn.co/euv5oav" class="btn">Buy Now</a>
        </div>

        <!-- Product 2 -->
        <div class="product">
            <div class="label">New</div>
            <img src="https://ae-pic-a1.aliexpress-media.com/kf/Sb403d6ab8e404d7b9f1c0f39a0b66c61A.jpg_960x960q75.jpg_.avif" alt="Casual Hoodie Sweatshirt">
            <h2>Casual Hoodie Sweatshirt</h2>
            <div class="price">$49.99</div>
            <a href="https://sovrn.co/gse84hm" class="btn">Buy Now</a>
        </div>

        <!-- Product 3 -->
        <div class="product">
            <div class="label">Sale</div>
            <img src="https://ae-pic-a1.aliexpress-media.com/kf/S525871b38db94b21846d6e65ca191d51F.jpg_960x960q75.jpg_.avif" alt="Multi-Pocket Crossbody Bag">
            <h2>Multi-Pocket Crossbody Bag</h2>
            <div class="price">$34.99</div>
            <a href="https://sovrn.co/1nkasu5" class="btn">Buy Now</a>
        </div>
    </div>

    <p>Deals are limited — grab yours before they're gone!</p>
</div>

</body>
</html>
